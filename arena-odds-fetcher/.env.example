# ---------------------------------------------------------------------------
# arena-odds-fetcher configuration
# Copy this file to ".env" and adjust. All values are optional except where
# noted; sensible defaults are baked in.
# ---------------------------------------------------------------------------

# HTTP port the service listens on.
PORT=8080

# Bind address. Use 127.0.0.1 to keep the service local-only (recommended if
# the DE server is reached via SSH tunnel), or 0.0.0.0 to expose it.
HOST=127.0.0.1

# Full-refresh interval in seconds. Default 120. Values below 60 are clamped
# to 60 (hard politeness limit, cannot be overridden).
REFRESH_SECONDS=120

# Token that protects POST /refresh. If left empty, manual refresh is DISABLED
# (returns 401). The background refresh loop always runs regardless.
# Send it as "Authorization: Bearer <token>" or "?token=<token>".
REFRESH_TOKEN=change-me-please

# User-Agent used for all outbound requests to the source.
SOURCE_USER_AGENT=arena-poc-odds/1.0

# Base URL of the Cashpoint odds service (discovered via DISCOVERY.md).
ODDS_BASE_URL=https://oddsservice-msw-mb-de.cashpoint.solutions

# Cashpoint request context headers. x-language=1 => German name resolution.
CP_SYSTEM_ID=1
CP_LANGUAGE=1
CP_LOCATION=82
CP_CLIENT_COUNTRY=82
CP_JURISDICTION_ID=1

# Where to write the snapshot after each successful refresh.
SNAPSHOT_PATH=./snapshots/odds-latest.json

# Log level: debug | info | warn | error
LOG_LEVEL=info

# HTTP timeout (ms) per upstream request.
REQUEST_TIMEOUT_MS=25000
