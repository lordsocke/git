# Kopie als .env anlegen (wird von tsx/dotenv NICHT automatisch geladen –
# Werte via `export` oder Prozess-Umgebung setzen; docker-compose deckt Postgres ab).
DATABASE_URL=postgres://arena:arena@localhost:5432/arena
JWT_SECRET=dev-only-insecure-secret-change-me
APPLE_CLIENT_ID=de.targetki.arena
SIGNUP_BONUS=1000
PORT=8080
NODE_ENV=development
